# Full host nginx example — matches existing dev EC2 layout (Certbot + tutor on :8080).
#
# Tutor Compose port: 127.0.0.1:8080  (GATEWAY_HTTP_PORT=8080)
# Admin Compose port: 127.0.0.1:81     (ADMIN_HTTP_PORT=81)
#
# If you already have dev.tutorix.tech configured, prefer:
#   docker/nginx/host-ec2-admin-snippet.conf.example

# Tutor — dev.tutorix.tech
server {
    server_name dev.tutorix.tech;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/dev.tutorix.tech/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dev.tutorix.tech/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

# Admin — dev-admin.tutorix.tech
server {
    server_name dev-admin.tutorix.tech;

    location / {
        proxy_pass http://127.0.0.1:81;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/dev.tutorix.tech/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dev.tutorix.tech/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

# HTTP → HTTPS
server {
    listen 80;
    server_name dev.tutorix.tech dev-admin.tutorix.tech;
    if ($host = dev.tutorix.tech) {
        return 301 https://$host$request_uri;
    }
    if ($host = dev-admin.tutorix.tech) {
        return 301 https://$host$request_uri;
    }
    return 404;
}
