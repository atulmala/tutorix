# Copy to `.env` in repo root before `docker compose up`, or export in shell.

# --- Required for API ---
JWT_SECRET=replace-with-long-random-secret

# Browser-visible origin for tutor app (CORS)
FRONTEND_URL=https://dev.tutorix.tech

# Comma-separated extra origins — include admin subdomain
CORS_ORIGINS=https://dev-admin.tutorix.tech

# Compose binds to localhost (host nginx terminates TLS on 443)
# Tutor must match your existing nginx proxy_pass port (default 8080 on dev EC2)
GATEWAY_HTTP_PORT=8080
ADMIN_HTTP_PORT=81

# API bind address inside container (default 0.0.0.0 — required for nginx proxy)
# LISTEN_HOST=0.0.0.0

# Build-time GraphQL path for web SPA (same-origin relative default works behind nginx)
# VITE_GRAPHQL_ENDPOINT=/api/graphql

# Database — Compose defaults below match postgres service
# DB_HOST=postgres
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_NAME=tutorix

# PostGIS Postgres volume bootstrap (postgres service only)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=tutorix

# Schema sync — auto-creates tables from entities on startup (safe for fresh Docker DB)
# Set to false and use migrations for a DB with existing data you want to preserve
DB_SYNCHRONIZE=true

# Migrations — .ts migration files cannot run inside the Docker webpack bundle.
# Use DB_SYNCHRONIZE=true instead for Docker. For EC2 with a real migrations setup, see docs/DEPLOYMENT_EC2.md
AUTO_RUN_MIGRATIONS=false

# AWS (S3 documents, optional Secrets Manager for DB in prod)
# AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1
# S3_DOCUMENTS_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# DOCUMENT_PUBLIC_BASE_URL=
# Prefer EC2 IAM instance profile over long-lived keys when possible (omit ACCESS_KEY_* on instance)
