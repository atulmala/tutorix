# Copy to `.env` in repo root before `docker compose up`, or export in shell.

# --- Required for API ---
JWT_SECRET=replace-with-long-random-secret

# Browser-visible origin(s); align with EC2 public URL or gateway hostname (scheme + host[:port])
FRONTEND_URL=http://localhost

# Optional: comma-separated extra origins (e.g. admin subdomain or staging URLs)
# CORS_ORIGINS=http://localhost:4201,https://admin.example.com

# Optional gateway bind port on host (defaults to 80)
# GATEWAY_HTTP_PORT=80

# Build-time GraphQL path for web SPA (same-origin relative default works behind nginx)
# VITE_GRAPHQL_ENDPOINT=/api/graphql

# Database — Compose defaults below match postgres service
# DB_HOST=postgres
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_NAME=tutorix

# PostGIS Postgres volume bootstrap (postgres service only)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=tutorix

# Migrations — runs automatically when API starts if true (see docs/DEPLOYMENT_EC2.md)
AUTO_RUN_MIGRATIONS=true

# AWS (S3 documents, optional Secrets Manager for DB in prod)
# AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1
# S3_DOCUMENTS_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
