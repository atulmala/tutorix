# Copy to `.env` in the repo root for local Nx development (not committed).
# For Docker Compose on a server, see `.env.docker.example`.

# --- API: database ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=tutorix

# --- API: required for auth ---
JWT_SECRET=replace-with-a-long-random-secret

# --- API: CORS / email links (student web origin) ---
FRONTEND_URL=http://localhost:4200

# Optional: extra origins (comma-separated), e.g. admin on another host
# CORS_ORIGINS=http://localhost:4201

# --- Web / admin (Vite): optional ---
# Defaults to http://localhost:3000/api/graphql if unset. Use full URL for local Nx.
# VITE_GRAPHQL_ENDPOINT=http://localhost:3000/api/graphql

# --- Optional convenience (not all are read by the apps) ---
# API_URL=http://localhost:3000
# WEB_URL=http://localhost:4200
# ADMIN_URL=http://localhost:4201

# --- API: S3 documents bucket (must match bucket region or presigned PUT returns 403) ---
# S3_DOCUMENTS_BUCKET=tutorix-documents-dev
# S3_DOCUMENTS_BUCKET_REGION=us-east-2
# AWS_REGION=us-east-2

# Optional: HTTPS/CDN base for document.originalUrl and thumbnail URL fields (matches metadata Lambda).
# DOCUMENT_PUBLIC_BASE_URL=https://cdn.example.com/my-prefix

# --- API: tutor document verification webhook (Lambda → API only) ---
# Same secret must be set on the tutor-document-verification Lambda.
# DOCUMENT_VERIFICATION_WEBHOOK_SECRET=long-random-secret
#
# Anthropic runs only in that Lambda (see lambdas/tutor-document-verification/) — not in the API.
